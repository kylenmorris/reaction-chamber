# --- General OS & Editor Junk ---
.DS_Store
Thumbs.db
*~
*.swp
*.bak
*.tmp

# --- IDEs (VS Code, IntelliJ, Eclipse) ---
.vscode/
.idea/
.settings/
*.code-workspace

# --- C/C++ & Embedded Build Artifacts ---
# Compiled Object files
*.o
*.obj
*.lo

# Executables and Libraries
*.exe
*.dll
*.so
*.dylib
*.a
*.lib

# Firmware / Embedded Outputs
*.hex
*.bin
*.elf
*.map
*.lst
*.d
*.srec

# --- KiCAD Specifics ---
# Backup files (auto-generated by KiCAD)
*-bak
*.kicad_pcb-bak
*.sch-bak
*.kicad_prl
*.kicad_sch-bak

# Temporary locks (Prevents saving over open files)
*.lck

# Footprint cache (Local to the machine)
fp-info-cache

# Netlists (Generated, can be regenerated from schematic)
*.net

# Gerber Files (Manufacturing outputs - usually better to zip these in releases than track source)
# Uncomment the line below if you generate gerbers into a 'gerbers' folder
# gerbers/
*.gbr
*.drl
*.pos
*.rpt

# --- Binary and Large Files ---
*.zip
*.tar.gz