# --- Default Behavior ---
# Auto-detect text files, normalize line endings to LF in the repo
* text=auto

# --- Source Code (Force LF) ---
# Ensure these always use Linux line endings to prevent compile errors or diff noise
*.c     text eol=lf
*.h     text eol=lf
*.cpp   text eol=lf
*.hpp   text eol=lf
*.ino   text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.xml   text eol=lf

# --- KiCAD Files ---
# Modern KiCAD files are text-based (S-expressions), but we want to ensure
# Git handles them consistently without corrupting the structure.
*.kicad_pro   text eol=lf
*.kicad_sch   text eol=lf
*.kicad_pcb   text eol=lf
*.kicad_mod   text eol=lf
*.kicad_wks   text eol=lf
*.kicad_sym   text eol=lf

# --- Diagrams & Documentation ---
# Draw.io (XML based) - Treat as text
*.drawio      text eol=lf

# Text-based diagrams (Mermaid, PlantUML)
*.mmd         text eol=lf
*.puml        text eol=lf

# --- Binary Files (DO NOT TOUCH) ---
# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary

# Documents
*.pdf binary
*.docx binary
*.pptx binary
*.xlsx binary

# Archives
*.zip binary
*.tar.gz binary
*.7z binary

# Embedded Binaries (just in case they aren't ignored)
*.hex binary
*.bin binary
*.elf binary
*.uf2 binary